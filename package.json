{
  "name": "coachfinder",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pipeline": "node --env-file=.env scripts/run-pipeline.js",
    "collect": "node --env-file=.env scripts/run-pipeline.js --collect",
    "collect:google": "node --env-file=.env scripts/collectors/google-places.js",
    "collect:kvk": "node --env-file=.env scripts/collectors/kvk-collector.js",
    "collect:nobco": "node --env-file=.env scripts/collectors/nobco-scraper.js",
    "collect:vind": "node --env-file=.env scripts/collectors/vind-een-coach.js",
    "collect:assoc": "node --env-file=.env scripts/collectors/association-scraper.js",
    "enrich": "node --env-file=.env scripts/enrichment/website-enricher.js",
    "enrich:reenrich": "node --env-file=.env scripts/enrichment/website-enricher.js --reenrich",
    "enrich:provinces": "node --env-file=.env scripts/enrichment/province-enricher.js",
    "score": "node --env-file=.env scripts/enrichment/quality-scorer.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "pinia": "^2.0.16",
    "undici": "^7.22.0",
    "vue": "^3.2.13",
    "vue-router": "^4.1.2"
  },
  "devDependencies": {
    "@netlify/vite-plugin": "^2.10.3",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10",
    "cheerio": "^1.0.0",
    "happy-dom": "^20.8.3",
    "p-limit": "^6.0.0",
    "postcss": "^8",
    "tailwindcss": "^3",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
